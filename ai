import random

n = 4
def calculate_fitness(individual):
    non_attacking_pairs = 0
    
    for i in range(0, n):
        for j in range(i+1, n):
            if individual[i] != individual[j] and abs(individual[i] - individual[j]) != abs(i-j):
                non_attacking_pairs += 1
    
    return non_attacking_pairs

